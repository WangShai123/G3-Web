# Wordpress - ignore core, configuration, examples, uploads and logs.
#
# Core
#
# Note: if you want to stage/commit WP core files
# you can delete this whole section/until Configuration.
/wp-admin/
/wp-includes/
/wp-content/index.php
/wp-content/languages
/wp-content/plugins/index.php
/wp-content/themes/index.php
/wp-content/upgrade/
/index.php
/license.txt
/readme.html
/wp-*.php
/xmlrpc.php

# Configuration
/wp-config.php
/.user.ini
/biome.json

# Uploads
/wp-content/uploads/

# Default themes
/wp-content/themes
/wp-content/themes/twenty*/

# Local files in plugin g3
/g3.php
/wp-content/plugins/g3/backup/
/wp-content/plugins/g3/documents/
/wp-content/plugins/g3/extensions/jl.php
#/wp-content/plugins/g3/dist/

# Advanced tests
/wp-content/plugins/g3/tests/
# Component tests
/wp-content/plugins/g3/src/Components/*/tests/

# Languages backup files
/wp-content/plugins/g3/public/languages/*.pot~
/wp-content/plugins/g3/public/languages/*.po~

# Tools
/wp-content/backup-*.php
/wp-content/object-cache.php
/wp-content/object-cache.php.bak
/wp-content/db.php

# Other plugins
/wp-content/plugins/loco-translate/
/wp-content/plugins/query-monitor/

# Tools
/.github
/.idea
/.vscode
/.lingma
/.trae
/*.txt

# Log files
/*.log
/wp-content/*.log

# htaccess
/.htaccess

# DS_Store
.DS_Store
