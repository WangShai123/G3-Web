# Wordpress - ignore core, configuration, examples, uploads and logs.
wp-admin/
wp-includes/
wp-content/index.php
wp-content/languages
wp-content/plugins/index.php
wp-content/themes/index.php
wp-content/upgrade/
wp-content/uploads/
index.php
license.txt
readme.html
wp-*.php
xmlrpc.php

# Configuration
.user.ini

# Default themes
wp-content/themes
wp-content/themes/twenty*/

# Local files in plugin g3
favicon.ico
g3.php
wp-content/plugins/*/
!wp-content/plugins/g3/
wp-content/plugins/g3/backup/
wp-content/plugins/g3/documents/
wp-content/plugins/g3/extensions/linux/
wp-content/plugins/g3/extensions/mac/
wp-content/plugins/g3/extensions/windows/
wp-content/plugins/g3/extensions/jl.php
wp-content/plugins/g3/node_modules/
wp-content/plugins/g3/package-lock.json
wp-content/plugins/g3/package.json
wp-content/plugins/g3/pnpm-lock.yaml
wp-content/plugins/g3/vite.config.ts

# g3 assets
wp-content/plugins/g3/assets/css/*
!wp-content/plugins/g3/assets/css/*.min.css
wp-content/plugins/g3/assets/javascript/**/*
!wp-content/plugins/g3/assets/javascript/**/*.min.js

# Tests
wp-content/plugins/g3/tests/
wp-content/plugins/g3/src/Core/*/tests/
wp-content/plugins/g3/src/Commands/TestCommand.php
wp-content/plugins/g3/src/Components/*/tests/
wp-content/plugins/g3/src/Controllers/TestController.php
wp-content/plugins/g3/templates/tests/
# Documentation markdown
wp-content/plugins/g3/bin/*.md
wp-content/plugins/g3/bin/**/*.md
wp-content/plugins/g3/src/*/*.md
wp-content/plugins/g3/src/Core/*/*.md
wp-content/plugins/g3/src/Core/*/*/*.md
# Examples
wp-content/plugins/g3/src/Examples/
wp-content/plugins/g3/src/Core/*/examples/

# Languages backup files
wp-content/plugins/g3/public/languages/*.pot~
wp-content/plugins/g3/public/languages/*.po~

# Uploads
wp-content/plugins/g3/public/images/svg/
wp-content/plugins/g3/public/images/unsplash/

# Cache
wp-content/plugins/g3/cache/routes.php

# Tools
wp-content/backup-*.php
wp-content/object-cache.php
wp-content/object-cache.php.bak
wp-content/db.php
sitemap
llm
document.md

# composer vendor markdown
wp-content/plugins/g3/vendor/**/*.md
wp-content/plugins/g3/vendor/**/LICENSE

# Tools
.github/
.idea/
.vscode/
.claude/
.codex/

# Log files
*.log
wp-content/*.log

# htaccess
.htaccess

# DS_Store
.DS_Store
